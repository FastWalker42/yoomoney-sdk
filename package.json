{
  "name": "@fw42/yoomoney",
  "version": "2.0.0",
  "description": "Runtime-agnostic TypeScript SDK for YooMoney Wallet API — payments, history, notifications, payment links",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "example:history": "tsx examples/get-history.ts",
    "example:details": "tsx examples/get-details.ts",
    "example:account": "tsx examples/get-account-info.ts",
    "example:check": "tsx examples/check-payment.ts"
  },
  "keywords": [
    "yoomoney",
    "yandex-money",
    "payment",
    "wallet",
    "api",
    "sdk",
    "bun",
    "deno"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
